# Docker image versions
POSTGRES_VERSION=17-alpine
KEYCLOAK_VERSION=26.1

# PostgreSQL (local development only)
POSTGRES_DB=keycloak
POSTGRES_USER=securetask
POSTGRES_PASSWORD=change-me-for-local-development
POSTGRES_PORT=5432

# Spring Boot database schema
APP_DATABASE_SCHEMA=securetask

# Keycloak development administrator
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-for-local-development
KEYCLOAK_PORT=8081

# Spring Boot backend
BACKEND_PORT=8080
