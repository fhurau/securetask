# Docker image versions
POSTGRES_VERSION=17-alpine
KEYCLOAK_VERSION=26.1
KAFKA_VERSION=3.8.0
REDIS_VERSION=7-alpine
PROMETHEUS_VERSION=v2.55.1
GRAFANA_VERSION=11.3.1

# PostgreSQL (local development only)
POSTGRES_DB=keycloak
POSTGRES_USER=securetask
POSTGRES_PASSWORD=change-me-for-local-development
POSTGRES_PORT=5432

# Spring Boot database schema
APP_DATABASE_SCHEMA=securetask

# Keycloak development administrator
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-for-local-development
KEYCLOAK_PORT=8081

# Kafka
KAFKA_PORT=9092

# Redis
REDIS_PORT=6379

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=change-me-for-local-development

# Spring Boot backend
BACKEND_PORT=8080
DOCUMENT_STORAGE_PATH=./data/uploads

# Next.js frontend
FRONTEND_PORT=3000
