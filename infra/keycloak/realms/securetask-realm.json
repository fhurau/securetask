{
  "realm": "securetask",
  "enabled": true,
  "displayName": "SecureTask",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Standard SecureTask user"
